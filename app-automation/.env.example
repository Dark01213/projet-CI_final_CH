# ===== INFORMATIONS VM AZURE =====
VM_HOST=your-azure-vm-ip-address
VM_USERNAME=your-ssh-username
VM_PORT=22

# ===== CLÉ SSH PRIVÉE =====
# Générer une clé SSH : ssh-keygen -t rsa -b 4096 -f ~/.ssh/id_rsa_azure
VM_SSH_KEY=your-private-ssh-key-here

# ===== DOCKER REGISTRY =====
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password
DOCKER_REGISTRY_URL=docker.io

# ===== DOCKER IMAGE TOKENS =====
DOCKER_TOKEN_BACKEND=your-backend-token
DOCKER_TOKEN_FRONTEND=your-frontend-token

# ===== VARIABLES D'APPLICATION =====
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-change-in-production

# ===== CONFIGURATION TERRAFORM =====
TERRAFORM_DEPLOYMENT=true
